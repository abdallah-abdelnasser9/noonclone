<%- include('../partials/header') %>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
                    </div>
                    
                    <h1 class="display-5 fw-bold text-success mb-3">Order Placed Successfully!</h1>
                    
                    <p class="lead mb-4">Thank you for your purchase. Your order has been received and is being processed.</p>
                    
                    <div class="alert alert-info">
                        <strong>Order ID:</strong> <%= orderId %>
                        <br>
                        <small>Please save this order ID for future reference.</small>
                    </div>
                    
                    <hr class="my-4">
                    
                    <p>You will receive an email confirmation shortly with your order details.</p>
                    
                    <div class="mt-4">
                        <a href="/orders/<%= orderId %>" class="btn btn-warning btn-lg me-2">
                            <i class="fas fa-eye"></i> View Order
                        </a>
                        <a href="/products/shop" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-shopping-cart"></i> Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="mt-4">
                <div class="row">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body text-center">
                                <i class="fas fa-truck fa-2x text-warning mb-2"></i>
                                <h6>Free Shipping</h6>
                                <small class="text-muted">On orders over $500</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body text-center">
                                <i class="fas fa-undo-alt fa-2x text-warning mb-2"></i>
                                <h6>Easy Returns</h6>
                                <small class="text-muted">30 days return policy</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body text-center">
                                <i class="fas fa-headset fa-2x text-warning mb-2"></i>
                                <h6>24/7 Support</h6>
                                <small class="text-muted">Dedicated customer support</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>