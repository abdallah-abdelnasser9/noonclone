<%- include('../partials/header') %>

<div class="container my-5">
    <h1 class="mb-4">My Orders</h1>
    
    <% if (orders && orders.length > 0) { %>
        <div class="row">
            <div class="col-12">
                <% orders.forEach(order => { %>
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <strong>Order #:</strong> <%= order._id.toString().slice(-8) %>
                                </div>
                                <div class="col-md-3">
                                    <strong>Date:</strong> <%= new Date(order.createdAt).toLocaleDateString() %>
                                </div>
                                <div class="col-md-3">
                                    <strong>Total:</strong> $<%= order.totalPrice.toFixed(2) %>
                                </div>
                                <div class="col-md-3">
                                    <span class="badge <%= order.orderStatus === 'Delivered' ? 'bg-success' : (order.orderStatus === 'Cancelled' ? 'bg-danger' : 'bg-warning') %>">
                                        <%= order.orderStatus %>
                                    </span>
                                    <span class="badge <%= order.paymentStatus === 'Paid' ? 'bg-success' : 'bg-secondary' %> ms-2">
                                        <%= order.paymentStatus %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <h6>Products:</h6>
                                    <% order.products.forEach(product => { %>
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div>
                                                <img src="/uploads/<%= product.image || 'default-product.jpg' %>" 
                                                     style="width: 50px; height: 50px; object-fit: cover;" 
                                                     class="rounded me-2">
                                                <%= product.title %>
                                            </div>
                                            <div>
                                                $<%= product.price.toFixed(2) %> x <%= product.quantity %> = $<%= (product.price * product.quantity).toFixed(2) %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                                <div class="col-md-4 text-end">
                                    <a href="/orders/<%= order._id %>" class="btn btn-warning btn-sm">
                                        <i class="fas fa-eye"></i> View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h3>No Orders Yet</h3>
            <p>You haven't placed any orders yet.</p>
            <a href="/products/shop" class="btn btn-warning">Start Shopping</a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>