<%- include('../partials/header') %>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
    <div id="cartToast" class="toast" role="alert">
        <div class="toast-header">
            <i class="fas fa-shopping-cart text-warning me-2"></i>
            <strong class="me-auto">Cart Update</strong>
            <small>Just now</small>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body" id="toastMessage"></div>
    </div>
</div>

<div class="container my-4">
    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-filter me-2"></i>Filters</h5>
                    <hr>
                    
                    <label class="form-label fw-bold">Category</label>
                    <select class="form-select mb-3" id="categoryFilter">
                        <option value="">All Categories</option>
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(function(cat) { %>
                                <option value="<%= cat._id %>" <%= currentCategory === cat._id.toString() ? 'selected' : '' %>>
                                    <%= cat.name %>
                                </option>
                            <% }); %>
                        <% } %>
                    </select>
                    
                    <label class="form-label fw-bold">Sort By</label>
                    <select class="form-select mb-3" id="sortFilter">
                        <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                        <option value="price_asc" <%= sortBy === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
                        <option value="price_desc" <%= sortBy === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
                    </select>
                    
                    <label class="form-label fw-bold">Price Range</label>
                    <div class="input-group input-group-sm mb-2">
                        <span class="input-group-text">$</span>
                        <input type="number" class="form-control" placeholder="Min" id="minPrice">
                    </div>
                    <div class="input-group input-group-sm mb-3">
                        <span class="input-group-text">$</span>
                        <input type="number" class="form-control" placeholder="Max" id="maxPrice">
                    </div>
                    
                    <button class="btn btn-warning w-100" onclick="applyFilters()">
                        <i class="fas fa-search me-1"></i> Apply Filters
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Products Grid -->
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0"><%= products ? products.length : 0 %> Products Found</h4>
                <a href="/products/shop" class="btn btn-outline-secondary btn-sm">Clear Filters</a>
            </div>
            
            <div class="row">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(function(product) { %>
                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card product-card h-100 shadow-sm border-0">
                                <!-- Product Image -->
                                <div class="product-img-wrapper position-relative" style="height: 220px; overflow: hidden;">
                                    <% if (product.mainImage && product.mainImage !== 'default-product.png') { %>
                                        <img src="<%= product.mainImage.startsWith('http') ? product.mainImage : '/uploads/products/' + product.mainImage %>" 
                                             alt="<%= product.name %>"
                                             class="w-100 h-100"
                                             style="object-fit: cover;"
                                             onerror="this.src='https://via.placeholder.com/400x300?text=No+Image'">
                                    <% } else { %>
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    <% } %>
                                    
                                    <!-- Wishlist Heart Button -->
                                    <button class="btn wishlist-btn position-absolute" 
                                            data-id="<%= product._id %>"
                                            style="top: 10px; right: 10px; background: white; border-radius: 50%; width: 36px; height: 36px; padding: 0; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                        <i class="far fa-heart text-danger"></i>
                                    </button>
                                    
                                    <% if (product.stock <= 0) { %>
                                        <span class="badge bg-danger position-absolute top-0 start-0 m-2">Out of Stock</span>
                                    <% } else if (product.stock < 10) { %>
                                        <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">Low Stock</span>
                                    <% } %>
                                </div>
                                
                                <!-- Product Info -->
                                <div class="card-body d-flex flex-column">
                                    <p class="text-muted small mb-1"><%= product.category ? product.category.name : 'Uncategorized' %></p>
                                    <h6 class="card-title mb-2" style="min-height: 40px;">
                                        <a href="/products/<%= product._id %>" class="text-decoration-none text-dark">
                                            <%= product.name %>
                                        </a>
                                    </h6>
                                    
                                    <div class="mt-auto">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="h5 text-warning mb-0 fw-bold">$<%= product.price.toFixed(2) %></span>
                                            <div class="text-warning small">
                                                <% if (product.averageRating > 0) { %>
                                                    <i class="fas fa-star"></i> <%= product.averageRating.toFixed(1) %>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Card Footer -->
                                <div class="card-footer bg-white border-0 pt-0">
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-warning btn-sm add-to-cart-btn flex-grow-1" data-id="<%= product._id %>" <%= product.stock <= 0 ? 'disabled' : '' %>>
                                            <i class="fas fa-cart-plus me-1"></i> Add to Cart
                                        </button>
                                        <a href="/products/<%= product._id %>" class="btn btn-outline-secondary btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fas fa-box-open fa-5x text-muted mb-4"></i>
                        <h3>No Products Found</h3>
                        <p class="text-muted">Try adjusting your filters or check back later for new products.</p>
                        <a href="/products/shop" class="btn btn-warning btn-lg mt-3">
                            <i class="fas fa-sync-alt me-2"></i>Clear Filters
                        </a>
                    </div>
                <% } %>
            </div>
            
            <!-- Pagination -->
            <% if (totalPages && totalPages > 1) { %>
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <% if (currentPage > 1) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPage - 1 %><%= searchQuery ? '&search=' + searchQuery : '' %><%= currentCategory ? '&category=' + currentCategory : '' %>">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                        <% } %>
                        
                        <% for(var i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %><%= searchQuery ? '&search=' + searchQuery : '' %><%= currentCategory ? '&category=' + currentCategory : '' %>">
                                    <%= i %>
                                </a>
                            </li>
                        <% } %>
                        
                        <% if (currentPage < totalPages) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPage + 1 %><%= searchQuery ? '&search=' + searchQuery : '' %><%= currentCategory ? '&category=' + currentCategory : '' %>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<style>
    .product-card {
        transition: all 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
    }
    
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
    }
    
    .product-img-wrapper {
        border-radius: 12px 12px 0 0;
    }
    
    .product-img-wrapper img {
        transition: transform 0.5s ease;
    }
    
    .product-card:hover .product-img-wrapper img {
        transform: scale(1.05);
    }
    
    .wishlist-btn {
        transition: all 0.3s ease;
        opacity: 0;
        transform: translateY(-5px);
    }
    
    .product-card:hover .wishlist-btn {
        opacity: 1;
        transform: translateY(0);
    }
    
    .wishlist-btn:hover {
        background: #dc3545 !important;
        color: white !important;
        transform: scale(1.1) !important;
    }
    
    .wishlist-btn:hover i {
        color: white !important;
    }
    
    .add-to-cart-btn {
        transition: all 0.3s ease;
    }
    
    .add-to-cart-btn:hover {
        transform: scale(1.05);
    }
    
    /* Dark Mode */
    .dark-mode .product-card {
        background-color: #2d2d2d;
        color: #fff;
    }
    
    .dark-mode .product-card .card-footer {
        background-color: #2d2d2d !important;
    }
    
    .dark-mode .product-card .card-body {
        background-color: #2d2d2d;
    }
    
    .dark-mode .product-card .card-title a {
        color: #fff !important;
    }
    
    .dark-mode .product-img-wrapper {
        background-color: #1a1a1a;
    }
    
    .dark-mode .wishlist-btn {
        background: #3d3d3d !important;
    }
</style>

<script>
// Toast function
function showToast(message, type) {
    var toastEl = document.getElementById('cartToast');
    var toastBody = document.getElementById('toastMessage');
    var icon = toastEl.querySelector('.toast-header i');
    var title = toastEl.querySelector('.toast-header strong');
    
    if (type === 'success') {
        icon.className = 'fas fa-check-circle text-success me-2';
        title.textContent = 'Success';
    } else if (type === 'error') {
        icon.className = 'fas fa-exclamation-circle text-danger me-2';
        title.textContent = 'Error';
    } else if (type === 'warning') {
        icon.className = 'fas fa-info-circle text-warning me-2';
        title.textContent = 'Notice';
    } else if (type === 'wishlist') {
        icon.className = 'fas fa-heart text-danger me-2';
        title.textContent = 'Wishlist';
    }
    
    toastBody.textContent = message;
    var toast = new bootstrap.Toast(toastEl, { delay: 3000 });
    toast.show();
}

// Filters
function applyFilters() {
    var params = new URLSearchParams();
    var category = document.getElementById('categoryFilter').value;
    var sort = document.getElementById('sortFilter').value;
    var minPrice = document.getElementById('minPrice').value;
    var maxPrice = document.getElementById('maxPrice').value;
    
    if (category) params.append('category', category);
    if (sort) params.append('sort', sort);
    if (minPrice) params.append('minPrice', minPrice);
    if (maxPrice) params.append('maxPrice', maxPrice);
    
    window.location.href = '/products/shop?' + params.toString();
}

// Cart & Wishlist
document.addEventListener('DOMContentLoaded', function() {
    // Add to Cart
    document.querySelectorAll('.add-to-cart-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.getAttribute('data-id');
            var button = this;
            var originalHTML = button.innerHTML;
            
            button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
            button.disabled = true;
            
            fetch('/cart/add/' + productId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                button.innerHTML = originalHTML;
                button.disabled = false;
                showToast(data.message || 'Added to cart!', data.success ? 'success' : 'error');
            })
            .catch(function() {
                button.innerHTML = originalHTML;
                button.disabled = false;
                showToast('Please login to add items', 'warning');
            });
        });
    });
    
    // Wishlist
    document.querySelectorAll('.wishlist-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var productId = this.getAttribute('data-id');
            var icon = this.querySelector('i');
            
            fetch('/user/wishlist/add/' + productId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    icon.className = 'fas fa-heart text-danger';
                    showToast('Added to wishlist!', 'wishlist');
                } else {
                    showToast(data.message || 'Already in wishlist', 'warning');
                }
            })
            .catch(function() {
                showToast('Please login to add to wishlist', 'warning');
            });
        });
    });
});
</script>

<%- include('../partials/footer') %>