<%- include('../partials/header') %>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Manage Products</h5>
                    <a href="/admin/products/add" class="btn btn-warning btn-sm">
                        <i class="fas fa-plus"></i> Add Product
                    </a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Image</th>
                                    <th>Title</th>
                                    <th>Price</th>
                                    <th>Category</th>
                                    <th>Stock</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (products && products.length > 0) { %>
                                    <% products.forEach(product => { %>
                                        <tr>
                                            <td>
                                                <img src="/uploads/<%= product.images && product.images[0] ? product.images[0] : 'default-product.jpg' %>" 
                                                     style="width: 60px; height: 60px; object-fit: cover;" 
                                                     class="rounded">
                                            </td>
                                            <td><%= product.title %></td>
                                            <td>$<%= product.price %></td>
                                            <td><%= product.category %></td>
                                            <td>
                                                <span class="badge <%= product.stock > 0 ? 'bg-success' : 'bg-danger' %>">
                                                    <%= product.stock %>
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/admin/products/edit/<%= product._id %>" class="btn btn-warning btn-sm">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button class="btn btn-danger btn-sm delete-product" data-id="<%= product._id %>">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center">No products found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('.delete-product').forEach(btn => {
    btn.addEventListener('click', async function() {
        if (confirm('Are you sure you want to delete this product?')) {
            const productId = this.dataset.id;
            const response = await fetch(`/admin/products/delete/${productId}`, {
                method: 'DELETE'
            });
            if (response.ok) {
                location.reload();
            } else {
                alert('Error deleting product');
            }
        }
    });
});
</script>

<%- include('../partials/footer') %>