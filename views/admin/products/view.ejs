<%- include('../partials/header') %>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body text-center">
                <img src="/uploads/products/<%= product.mainImage || 'default-product.png' %>" 
                     alt="<%= product.name %>" class="img-fluid rounded mb-3" style="max-height: 300px;">
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><%= product.name %></h5>
                <div>
                    <a href="/admin/products/edit/<%= product._id %>" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                    <a href="/admin/products" class="btn btn-secondary btn-sm">Back</a>
                </div>
            </div>
            <div class="card-body">
                <h3 class="text-primary mb-3">$<%= product.price.toFixed(2) %></h3>
                <p><strong>Category:</strong> <%= product.category ? product.category.name : 'N/A' %></p>
                <p><strong>Stock:</strong> <%= product.stock %></p>
                <p><strong>Status:</strong> 
                    <span class="badge bg-<%= product.isActive ? 'success' : 'secondary' %>">
                        <%= product.isActive ? 'Active' : 'Inactive' %>
                    </span>
                </p>
                <hr>
                <h6>Description</h6>
                <p><%= product.description %></p>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>