<%- include('../partials/header') %>

<% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i><%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-box me-2"></i>Products</h5>
        <a href="/admin/products/create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Product
        </a>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <form action="/admin/products" method="GET" class="d-flex">
                    <input type="text" name="search" class="form-control me-2" placeholder="Search..." value="<%= search || '' %>">
                    <button type="submit" class="btn btn-outline-primary"><i class="fas fa-search"></i></button>
                </form>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <tr>
                                <td>
                                    <img src="/uploads/products/<%= product.mainImage || 'default-product.png' %>" 
                                         style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                </td>
                                <td><%= product.name %></td>
                                <td><%= product.category ? product.category.name : 'N/A' %></td>
                                <td>$<%= product.price.toFixed(2) %></td>
                                <td>
                                    <span class="badge bg-<%= product.stock > 10 ? 'success' : product.stock > 0 ? 'warning' : 'danger' %>">
                                        <%= product.stock %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-<%= product.isActive ? 'success' : 'secondary' %>">
                                        <%= product.isActive ? 'Active' : 'Inactive' %>
                                    </span>
                                </td>
                                <td>
                                    <a href="/admin/products/<%= product._id %>" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                    <a href="/admin/products/edit/<%= product._id %>" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                    <form action="/admin/products/delete/<%= product._id %>" method="POST" style="display: inline;" 
                                          onsubmit="return confirm('Delete this product?');">
                                        <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-4">No products found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <nav>
                <ul class="pagination justify-content-center">
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                            <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
                        </li>
                    <% } %>
                </ul>
            </nav>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>