<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(135deg, #0b1025 0%, #764ba2 100%);
            color: white;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.8);
            padding: 12px 20px;
            margin: 4px 12px;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: rgba(255,255,255,0.2);
            color: white;
            transform: translateX(5px);
        }
        .sidebar .nav-link i { margin-right: 10px; width: 20px; }
        .main-content { margin-left: 250px; }
        .card { border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .stat-card {
            background: white; padding: 25px; border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: transform 0.3s;
        }
        .stat-card:hover { transform: translateY(-5px); }
        .btn { border-radius: 8px; padding: 8px 20px; }
        .badge { padding: 8px 12px; border-radius: 6px; }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar position-fixed" style="width: 250px; top: 0; bottom: 0; overflow-y: auto;">
            <div class="p-4">
                <h4 class="text-white mb-4"><i class="fas fa-crown me-2"></i>Admin Panel</h4>
                <hr class="bg-light">
            </div>
            
            <nav class="nav flex-column">
                <% 
                // Set default activePage if not defined
                var currentActive = typeof activePage !== 'undefined' ? activePage : 'dashboard';
                %>
                <a href="/admin/dashboard" class="nav-link <%= currentActive === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/admin/products" class="nav-link <%= currentActive === 'products' ? 'active' : '' %>">
                    <i class="fas fa-box"></i> Products
                </a>
                <a href="/admin/categories" class="nav-link <%= currentActive === 'categories' ? 'active' : '' %>">
                    <i class="fas fa-tags"></i> Categories
                </a>
                <a href="/admin/orders" class="nav-link <%= currentActive === 'orders' ? 'active' : '' %>">
                    <i class="fas fa-shopping-cart"></i> Orders
                </a>
                <a href="/admin/users" class="nav-link <%= currentActive === 'users' ? 'active' : '' %>">
                    <i class="fas fa-users"></i> Users
                </a>
                <hr class="bg-light mx-3">
                <a href="/logout" class="nav-link text-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </nav>
        </div>
        
        <div class="main-content flex-grow-1" style="margin-left: 250px;">
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
                <div class="container-fluid px-4">
                    <span class="navbar-brand mb-0 h1"><%= title %></span>
                    <div class="d-flex align-items-center">
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-2"></i>
                                <%= user ? user.name : 'Admin' %>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
    <li><a class="dropdown-item" href="/admin/profile"><i class="fas fa-user me-2"></i>Profile</a></li>
    <li><hr class="dropdown-divider"></li>
    <li><a class="dropdown-item text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
</ul>
                        </div>
                    </div>
                </div>
            </nav>
            
            <div class="p-4">