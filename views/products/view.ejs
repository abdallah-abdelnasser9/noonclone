<%- include('../partials/header') %>

<style>
    .product-image-container {
        height: 400px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 15px;
        overflow: hidden;
        position: relative;
    }
    .product-image-container img {
        max-width: 100%;
        max-height: 400px;
        object-fit: contain;
        transition: transform 0.3s ease;
    }
    .product-image-container img:hover {
        transform: scale(1.05);
    }
    .no-image-placeholder {
        color: #adb5bd;
        text-align: center;
    }
    .no-image-placeholder i {
        font-size: 5rem;
        display: block;
        margin-bottom: 1rem;
    }
    
    /* Toast Notification Styles */
    .toast-container {
        z-index: 9999;
    }
    .custom-toast {
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(0, 0, 0, 0.08);
        box-shadow: 0 20px 35px rgba(0, 0, 0, 0.2);
        border-radius: 16px;
        min-width: 300px;
        animation: slideInRight 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }
    @keyframes slideInRight {
        0% {
            opacity: 0;
            transform: translateX(100px);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }
    @keyframes slideOutRight {
        0% {
            opacity: 1;
            transform: translateX(0);
        }
        100% {
            opacity: 0;
            transform: translateX(100px);
        }
    }
    .toast-header {
        background: transparent;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .toast-body {
        font-weight: 500;
    }
</style>

<!-- Toast Notification Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="notificationToast" class="custom-toast toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-3 fw-semibold" id="toastMessage">
                <i id="toastIcon" class="fas fa-check-circle text-success fs-5"></i>
                <span id="toastText">Notification</span>
            </div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/products/shop">Shop</a></li>
            <li class="breadcrumb-item active"><%= product.name %></li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="product-image-container">
                    <% 
                        // Determine the correct image path
                        let imagePath = '/uploads/default-product.jpg';
                        let hasImage = false;
                        
                        if (product.mainImage && product.mainImage !== 'default-product.png' && product.mainImage !== '') {
                            imagePath = product.mainImage.startsWith('http') 
                                ? product.mainImage 
                                : '/uploads/products/' + product.mainImage;
                            hasImage = true;
                        } else if (product.images && product.images.length > 0 && product.images[0] !== 'default-product.png') {
                            imagePath = product.images[0].startsWith('http') 
                                ? product.images[0] 
                                : '/uploads/products/' + product.images[0];
                            hasImage = true;
                        } else if (product.image && product.image !== 'default-product.png') {
                            imagePath = product.image.startsWith('http') 
                                ? product.image 
                                : '/uploads/products/' + product.image;
                            hasImage = true;
                        }
                    %>
                    
                    <% if (hasImage) { %>
                        <img src="<%= imagePath %>" 
                             alt="<%= product.name %>"
                             onerror="this.style.display='none'; this.parentElement.querySelector('.no-image-placeholder').style.display='block';">
                        <div class="no-image-placeholder" style="display: none;">
                            <i class="fas fa-image"></i>
                            <span>Image not found</span>
                        </div>
                    <% } else { %>
                        <div class="no-image-placeholder">
                            <i class="fas fa-image"></i>
                            <span>No Image Available</span>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <h2 class="fw-bold"><%= product.name %></h2>
            <p class="text-muted">Category: <%= product.category ? (typeof product.category === 'object' ? product.category.name : product.category) : 'N/A' %></p>
            
            <h3 class="text-warning mb-3 fw-bold">$<%= (product.price || 0).toFixed(2) %></h3>
            
            <p><strong>Availability:</strong> 
                <% if (product.stock > 0) { %>
                    <span class="text-success fw-semibold">In Stock (<%= product.stock %> available)</span>
                <% } else { %>
                    <span class="text-danger fw-semibold">Out of Stock</span>
                <% } %>
            </p>
            
            <p class="text-muted"><%= product.description || 'No description available' %></p>
            
            <div class="d-flex gap-2 mt-4">
                <a href="/products/shop" class="btn btn-outline-secondary rounded-pill">
                    <i class="fas fa-arrow-left me-2"></i>Back to Shop
                </a>
                <% if (product.stock > 0) { %>
                    <button class="btn btn-warning rounded-pill add-to-cart-btn" data-id="<%= product._id %>">
                        <i class="fas fa-cart-plus me-2"></i>Add to Cart
                    </button>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
// Professional Toast Notification System
function showNotification(message, type = 'success') {
    const toastEl = document.getElementById('notificationToast');
    const toastIcon = document.getElementById('toastIcon');
    const toastText = document.getElementById('toastText');
    
    if (!toastEl || !toastIcon || !toastText) return;
    
    // Reset icon classes
    let iconClass = '';
    let iconColor = '';
    
    switch(type) {
        case 'success':
            iconClass = 'fa-check-circle';
            iconColor = 'text-success';
            break;
        case 'error':
            iconClass = 'fa-exclamation-circle';
            iconColor = 'text-danger';
            break;
        case 'warning':
            iconClass = 'fa-exclamation-triangle';
            iconColor = 'text-warning';
            break;
        case 'info':
            iconClass = 'fa-info-circle';
            iconColor = 'text-primary';
            break;
        case 'cart':
            iconClass = 'fa-shopping-cart';
            iconColor = 'text-success';
            break;
        default:
            iconClass = 'fa-bell';
            iconColor = 'text-primary';
    }
    
    toastIcon.className = `fas ${iconClass} ${iconColor} fs-5`;
    toastText.textContent = message;
    
    // Show the toast
    const toast = new bootstrap.Toast(toastEl, {
        delay: 3000,
        animation: true
    });
    toast.show();
}

// Add to cart functionality
document.querySelector('.add-to-cart-btn')?.addEventListener('click', function() {
    const productId = this.getAttribute('data-id');
    const button = this;
    const originalHTML = button.innerHTML;
    
    // Show loading state
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Adding...';
    button.disabled = true;
    
    fetch('/cart/add/' + productId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            showNotification(data.message || 'Product added to cart successfully! 🎉', 'cart');
            // Update cart count if available
            const cartBadge = document.querySelector('.cart-count');
            if (cartBadge && data.cartCount) {
                cartBadge.textContent = data.cartCount;
                // Add a subtle animation to the cart badge
                cartBadge.style.transform = 'scale(1.3)';
                setTimeout(() => {
                    cartBadge.style.transform = 'scale(1)';
                }, 300);
            }
        } else {
            showNotification(data.message || 'Failed to add product to cart', 'error');
        }
    })
    .catch(() => {
        showNotification('Please login to add items to your cart', 'warning');
    })
    .finally(() => {
        // Reset button state
        button.innerHTML = originalHTML;
        button.disabled = false;
    });
});

// Add subtle cart badge animation style
const style = document.createElement('style');
style.textContent = `
    .cart-count {
        transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        display: inline-block;
    }
`;
document.head.appendChild(style);
</script>

<%- include('../partials/footer') %>