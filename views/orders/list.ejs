<%- include('../partials/header') %>

<div class="container my-4">
    <h2 class="mb-4"><i class="fas fa-shopping-bag me-2"></i>My Orders</h2>
    
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (orders && orders.length > 0) { %>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Order ID</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td><strong>#<%= order._id.toString().slice(-8) %></strong></td>
                            <td><%= order.createdAt ? new Date(order.createdAt).toLocaleDateString() : 'N/A' %></td>
                            <td><%= order.items ? order.items.length : 0 %> items</td>
                            <td><strong>$<%= (order.totalAmount || 0).toLocaleString() %></strong></td>
                            <td>
                                <% 
                                let statusColor = 'warning';
                                if (order.status === 'processing') statusColor = 'info';
                                else if (order.status === 'shipped') statusColor = 'primary';
                                else if (order.status === 'delivered') statusColor = 'success';
                                else if (order.status === 'cancelled') statusColor = 'danger';
                                %>
                                <span class="badge bg-<%= statusColor %>"><%= order.status || 'pending' %></span>
                            </td>
                            <td>
                                <a href="/orders/<%= order._id %>" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h4>No orders yet</h4>
            <p>Start shopping and place your first order!</p>
            <a href="/products/shop" class="btn btn-warning mt-2">Browse Products</a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>