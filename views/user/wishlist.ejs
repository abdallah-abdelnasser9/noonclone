<%- include('../partials/header') %>

<div class="container my-4">
    <h2 class="mb-4"><i class="fas fa-heart text-danger me-2"></i>My Wishlist</h2>
    
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>
    
    <% if (wishlist && wishlist.length > 0) { %>
        <div class="row">
            <% wishlist.forEach(item => { %>
                <div class="col-md-3 mb-4">
                    <div class="card h-100">
                        <img src="<%= item.mainImage && item.mainImage.startsWith('http') ? item.mainImage : '/uploads/products/' + item.mainImage %>" 
                             class="card-img-top" alt="<%= item.name %>"
                             style="height: 200px; object-fit: cover;"
                             onerror="this.src='https://via.placeholder.com/300x300?text=No+Image'">
                        <div class="card-body">
                            <h6><%= item.name %></h6>
                            <p class="text-warning fw-bold">$<%= item.price ? item.price.toFixed(2) : '0.00' %></p>
                            <a href="/products/<%= item._id %>" class="btn btn-outline-warning btn-sm w-100 mb-2">View Details</a>
                            <form action="/user/wishlist/remove/<%= item._id %>" method="POST">
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                    <i class="fas fa-trash me-1"></i>Remove
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="fas fa-heart-broken fa-4x text-muted mb-3"></i>
            <h4>Your wishlist is empty</h4>
            <a href="/products/shop" class="btn btn-warning mt-3">Browse Products</a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>